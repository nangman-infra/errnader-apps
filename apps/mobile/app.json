{
  "expo": {
    "name": "errander",
    "slug": "errander",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "errander",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.errander.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.errander.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "사진을 첨부하려면 앨범 접근 권한이 필요해요.",
          "cameraPermission": "사진을 촬영하려면 카메라 접근 권한이 필요해요."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "39ea9c60-622b-49c2-9a25-24cf11062a4f"
      }
    },
    "owner": "junoshon"
  }
}
